PORT=3000
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=super-secret-change-me
APP_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/db_wizard
APP_DATABASE_SSLMODE=disable
APP_DATABASE_SSL_REJECT_UNAUTHORIZED=false
APP_ENCRYPTION_KEY=change-this-to-a-long-random-secret
TARGET_DB_SSLMODE=disable
TARGET_DB_SSL_REJECT_UNAUTHORIZED=false

SEED_DEMO_USERNAME=admin
SEED_DEMO_PASSWORD=admin123
SEED_ANALYST_USERNAME=analyst
SEED_ANALYST_PASSWORD=analyst123
SEED_VIEWER_USERNAME=viewer
SEED_VIEWER_PASSWORD=viewer123
# Optional override with JSON array:
# SEED_USERS_JSON=[{"username":"admin","password":"admin123","role":"admin","max_connections":50},{"username":"analyst","password":"analyst123","role":"user","max_connections":10}]

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_CALLBACK_URL=http://localhost:3000/auth/azure/callback
AZURE_TENANT=common

# Optional invite email delivery webhook used for admin-created user invites.
# Receives JSON payload: { to, from, subject, text, html, meta }
EMAIL_DELIVERY_WEBHOOK_URL=
EMAIL_FROM=no-reply@db-wizard.local
EMAIL_USE_SMTP=true
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
SMTP_TLS_REJECT_UNAUTHORIZED=false
SMTP_USER=
SMTP_PASS=
PASSWORD_SETUP_EXPIRES_HOURS=24
EMAIL_CONFIRM_EXPIRES_HOURS=24

# If true, application will run seed automatically during startup.
SEED_ON_STARTUP=false
